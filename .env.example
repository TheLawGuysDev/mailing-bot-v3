# Copiar a .env y completar. En Cloud Run puedes omitir DATABASE_URL (usa SQLite en /tmp).

APP_ENV=local

# Opcional. Si no se define → sqlite:////tmp/mailing_bot.db (efímero en Cloud Run).
# DATABASE_URL=sqlite:////data/mailing_bot.db
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# --- Mínimo para que arranque la app (configúralo en Cloud Run / Secret Manager)
STANNP_API_KEY=

# --- Recomendado en producción (JWT); en dev viene un default débil
# SECRET_KEY=

STANNP_BASE_URL=https://us.stannp.com/api/v1
STANNP_API_V1=https://api-us1.stannp.com/v1
STANNP_TEST_MODE=true

# Monday (opcional si solo usas login / core)
MONDAY_API_TOKEN=
MONDAY_API_URL=https://api.monday.com/v2
MONDAY_SIGNING_SECRET=

# Primer admin si la tabla users está vacía (misma lógica que al arrancar sin usuarios)
# BOOTSTRAP_ADMIN_EMAIL=admin@thelawguys.com
# BOOTSTRAP_ADMIN_PASSWORD=
# SKIP_AUTO_BOOTSTRAP_ADMIN=true

GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DRIVE_SHARED_DRIVE_ID=
GCS_BUCKET=
